			<Filename>synaptic.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-users.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>thunar.desktop</Filename>
		</Exclude>
	</Menu>
	<Menu>
		<Name>Accessories</Name>
		<Exclude>
			<Filename>org.gnome.Characters.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Include>
			<Filename>nemo.desktop</Filename>
		</Include>
		<Exclude>
			<Filename>org.gnome.font-viewer.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>yelp.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.TextEditor.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-onscreen-keyboard.desktop</Filename>
		</Exclude>
		<Include>
			<Filename>org.gnome.Screenshot.desktop</Filename>
		</Include>
		<Exclude>
			<Filename>info.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>caffeine-indicator.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>caffeine.desktop</Filename>
		</Exclude>
	</Menu>
	<Menu>
		<Name>Graphics</Name>
		<Exclude>
			<Filename>org.gnome.eog.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Exclude>
			<Filename>display-im6.q16.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.gThumb.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.Shotwell.desktop</Filename>
		</Exclude>
		<Include>
			<Filename>libreoffice-draw.desktop</Filename>
		</Include>
		<Exclude>
			<Filename>org.gnome.Evince.desktop</Filename>
		</Exclude>
	</Menu>
	<Menu>
		<Name>Office</Name>
		<Exclude>
			<Filename>org.gnome.Evince.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<DirectoryDir>/home/t/.local/share/desktop-directories</DirectoryDir>
	</Menu>
	<Menu>
		<Name>Other</Name>
		<Include>
			<Filename>gnome-disk-image-writer.desktop</Filename>
		</Include>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Include>
			<Filename>gnome-disk-image-mounter.desktop</Filename>
		</Include>
		<Include>
			<Filename>qemu.desktop</Filename>
		</Include>
	</Menu>
	<Menu>
		<Name>Internet</Name>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Include>
			<Filename>org.remmina.Remmina-file.desktop</Filename>
		</Include>
		<Layout>
			<Merge type="menus"/>
			<Filename>snap-store_snap-store.desktop</Filename>
			<Filename>snap-store_show-updates.desktop</Filename>
			<Filename>com.google.Chrome.desktop</Filename>
			<Filename>google-chrome.desktop</Filename>
			<Filename>org.remmina.Remmina-file.desktop</Filename>
			<Filename>org.remmina.Remmina.desktop</Filename>
			<Filename>slack_slack.desktop</Filename>
			<Filename>thunderbird.desktop</Filename>
			<Filename>thunderbird_thunderbird.desktop</Filename>
			<Filename>transmission-gtk.desktop</Filename>
			<Filename>Zoom.desktop</Filename>
			<Filename>teams-for-linux_teams-for-linux.desktop</Filename>
			<Merge type="files"/>
		</Layout>
	</Menu>
	<Menu>
		<Name>Multimedia</Name>
		<Include>
			<Filename>plex-desktop_plex-desktop.desktop</Filename>
		</Include>
		<AppDir>/home/t/.local/share/applications</AppDir>
	</Menu>
</Menu>
