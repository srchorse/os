		<Exclude>
			<Filename>cinnamon-settings-startup.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-screensaver.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-privacy.desktop</Filename>
		</Exclude>
		<Include>
			<Filename>cinnamon-settings.desktop</Filename>
		</Include>
		<Exclude>
			<Filename>guake-prefs.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-wacom-panel.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-user.desktop</Filename>
		</Exclude>
		<Include>
			<Filename>cinnamon-settings-backgrounds.desktop</Filename>
		</Include>
	</Menu>
	<Menu>
		<Name>Development</Name>
		<Exclude>
			<Filename>flutter_openurl.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
	</Menu>
	<Menu>
		<Name>Administration</Name>
		<Exclude>
			<Filename>lightdm-settings.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Exclude>
			<Filename>org.gnome.Logs.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>system-config-printer.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.PowerStats.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>gdebi.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.Terminal.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.gnome.SystemMonitor.desktop</Filename>
