			<Filename>cinnamon-settings-general.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-hotcorner.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>org.freedesktop.IBus.Setup.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-keyboard.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-mouse.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-power.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-network-panel.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>cinnamon-settings-workspaces.desktop</Filename>
