<?xml version="1.0" ?>
<!DOCTYPE Menu
  PUBLIC '-//freedesktop//DTD Menu 1.0//EN'
  'http://standards.freedesktop.org/menu-spec/menu-1.0.dtd'>
<Menu>
	<Name>Applications</Name>
	<MergeFile type="parent">/etc/xdg/menus/cinnamon-applications.menu</MergeFile>
	<Menu>
		<Name>Games</Name>
		<DirectoryDir>/home/t/.local/share/desktop-directories</DirectoryDir>
	</Menu>
	<Menu>
		<Name>Preferences</Name>
		<DirectoryDir>/home/t/.local/share/desktop-directories</DirectoryDir>
		<Exclude>
			<Filename>cinnamon-settings-universal-access.desktop</Filename>
		</Exclude>
		<AppDir>/home/t/.local/share/applications</AppDir>
		<Exclude>
			<Filename>software-properties-drivers.desktop</Filename>
		</Exclude>
		<Exclude>
			<Filename>nm-connection-editor.desktop</Filename>
		</Exclude>
		<Exclude>
